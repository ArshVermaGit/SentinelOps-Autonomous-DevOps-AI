# SentinelOps Environment Configuration
# Default: SQLite for local development (no Docker needed)
# For production with PostgreSQL, uncomment the line below:
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/sentinelops

DATABASE_URL=sqlite+aiosqlite:///./sentinelops.db
REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=sk-placeholder
GITHUB_TOKEN=ghp_placeholder
GITHUB_WEBHOOK_SECRET=sentinelops_secret
DEBUG=true
